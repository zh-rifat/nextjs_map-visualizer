# =============================================================================
# Google Sheet reader — environment variables
# =============================================================================
#
# These three variables are required to read a Google Sheet from the app.
# They come from a Google Cloud service account that has been granted access
# to the sheet (Share the sheet with the service-account email and give it
# at least "Viewer" permission).
#
# How to obtain them:
#   1. Open Google Cloud Console:
#        https://console.cloud.google.com/iam-admin/serviceaccounts
#   2. Create (or pick) a service account. Copy its email address — this is
#      the value for GOOGLE_CLIENT_ID below.
#   3. Open the service account → Keys → Add Key → Create new key → JSON.
#      A .json file downloads to your machine.
#   4. Open the downloaded JSON file. You need two fields:
#        - "client_email"  → goes into GOOGLE_CLIENT_ID
#        - "private_key"   → goes into GOOGLE_PRIVATE_KEY
#        - "sheet_id" is NOT in the JSON — it's the long ID in your sheet URL
#          between /d/ and /edit. Example:
#            https://docs.google.com/spreadsheets/d/1AbC...XyZ/edit#gid=0
#                                             ^^^^^^^^^^^^^^^^
#                                             this is GOOGLE_SHEET_ID
#   5. Share the Google Sheet with the service-account email (the
#      client_email from step 4) and give it at least "Viewer".
#
# -----------------------------------------------------------------------------

# Service-account email. Looks like: my-sa@my-project.iam.gserviceaccount.com
# IMPORTANT: this is the SERVICE ACCOUNT EMAIL (the `client_email` field in
# the JSON key file), NOT the OAuth numeric client ID. The OAuth numeric ID
# will NOT work for the JWT-bearer flow.
GOOGLE_CLIENT_ID=

# Service-account RSA private key. Paste the value of the `private_key` field
# from the JSON key file. You can paste it with real newlines OR with literal
# \n escapes; the utility will normalize either form.
# Example with literal \n escapes (recommended for .env):
#   GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBAD...rest of key...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# Spreadsheet ID. The long ID in the sheet URL between /d/ and /edit.
GOOGLE_SHEET_ID=

# Optional: default A1-notation range to fetch, e.g. "Sheet1!A1:Z" or "Users!A1:D".
# Defaults to "A1:Z" (first tab, all columns).
# GOOGLE_SHEET_RANGE=Sheet1!A1:Z